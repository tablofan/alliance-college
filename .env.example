# ============================================================
# Alliance College scraper — credentials & target config
# ------------------------------------------------------------
# Copy this file to `.env` and fill in your real values.
# `.env` is in .gitignore — never commit it.
# ============================================================

# Login URL for your aXcelerate tenant.
# Common patterns:
#   https://app.axcelerate.com/learner/
#   https://<tenant>.axcelerate.com/learner/
# If the script lands on the wrong page, paste your tenant's
# actual learner-portal URL here (the one you see in the browser
# bar after logging in normally).
AX_LOGIN_URL=https://app.axcelerate.com/learner/

# Your learner credentials.
AX_EMAIL=
AX_PASSWORD=

# Text fragment to match on the course-card you want to open.
# Case-insensitive; partial match.
AX_COURSE_MATCH=Land Agent

# Optional. Set to "1" to run with the browser hidden (headless).
# Recommended: leave as "0" so you can complete MFA in the window
# and watch the script work.
AX_HEADLESS=0
